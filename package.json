{
  "name": "c64-reverse-engineering-mcp",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "description": "MCP server for C64 reverse engineering — analysis pipeline, disassembly, and semantic classification",
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "tsc -p tsconfig.json && tsc -p pipeline/tsconfig.json && node scripts/fix-pipeline-ext.mjs",
    "build:mcp": "tsc -p tsconfig.json",
    "build:pipeline": "tsc -p pipeline/tsconfig.json && node scripts/fix-pipeline-ext.mjs",
    "build:c64ref": "tsx src/c64ref-rom-knowledge.ts",
    "bootstrap:workspace": "npm run build:mcp && node scripts/bootstrap-existing-re-workspace.mjs",
    "test:project-knowledge": "npm run build:mcp && node scripts/project-knowledge-smoke.mjs",
    "ui:api": "tsx src/workspace-ui/server.ts --api-only",
    "ui:dev": "vite --config ui/vite.config.ts --host 0.0.0.0 --port 4311",
    "ui:build": "vite build --config ui/vite.config.ts",
    "ui:typecheck": "tsc -p ui/tsconfig.json",
    "ui:serve": "tsx src/workspace-ui/server.ts",
    "ui:fixture": "npm run ui:build && npm run ui:serve -- --project fixtures/ui-smoke-project",
    "bootstrap:ui-fixture": "npm run build && node scripts/bootstrap-ui-fixture.mjs",
    "headless:mm:g64-debug": "npm run build:mcp && node scripts/headless-mm-g64-debug.mjs",
    "test:bus-trace": "npm run build:mcp && node scripts/bus-trace-motm.mjs",
    "trace:motm-vice-full": "npm run build:mcp && node scripts/vice-full-trace.mjs",
    "trace:motm-vice": "npm run build:mcp && node scripts/vice-iec-capture.mjs",
    "trace:motm-vice-swimlane": "npm run build:mcp && node scripts/vice-iec-capture.mjs --swimlane",
    "trace:motm-headless-swimlane": "npm run build:mcp && node scripts/headless-swimlane-capture.mjs",
    "trace:motm-headless-full": "npm run build:mcp && node scripts/headless-full-trace.mjs",
    "trace:motm-diff": "node scripts/vice-iec-diff.mjs",
    "trace:motm-swimlane-diff": "node scripts/swimlane-diff-v2.mjs",
    "probe:motm": "npm run build:mcp && node scripts/probe-motm.mjs",
    "trace:eof": "npm run build:mcp && node scripts/trace-eof.mjs",
    "trace:eof:vice": "npm run build:mcp && node scripts/trace-eof-vice.mjs",
    "trace:eof:diff": "node scripts/swimlane-diff.mjs --mode=eof",
    "smoke:gen": "npm run build:mcp && node scripts/gen-synthetic-disks.mjs",
    "smoke:load": "npm run build:mcp && node scripts/smoke-load.mjs",
    "smoke:stepping": "npm run build:mcp && node scripts/smoke-stepping.mjs",
    "smoke:reset": "npm run build:mcp && node scripts/smoke-reset-determinism.mjs",
    "smoke:snapshot": "npm run build:mcp && node scripts/smoke-snapshot.mjs",
    "smoke:drive-equiv": "npm run build:mcp && node scripts/smoke-drive-equiv.mjs",
    "smoke:via1-iec": "npm run build:mcp && node scripts/smoke-via1-iec.mjs",
    "smoke:serial-matrix": "npm run build:mcp && node scripts/smoke-serial-matrix.mjs",
    "smoke:g64-fidelity": "npm run build:mcp && node scripts/smoke-g64-fidelity.mjs",
    "smoke:write-support": "npm run build:mcp && node scripts/smoke-write-support.mjs",
    "smoke:multi-drive": "npm run build:mcp && node scripts/smoke-multi-drive.mjs",
    "smoke:fidelity-backlog": "npm run build:mcp && node scripts/smoke-fidelity-backlog.mjs",
    "smoke:cpu-fidelity": "npm run build:mcp && node scripts/smoke-cpu-fidelity.mjs",
    "smoke:cia-fidelity": "npm run build:mcp && node scripts/smoke-cia-fidelity.mjs",
    "smoke:vic-fidelity": "npm run build:mcp && node scripts/smoke-vic-fidelity.mjs",
    "smoke:pla-fidelity": "npm run build:mcp && node scripts/smoke-pla-fidelity.mjs",
    "smoke:input-fidelity": "npm run build:mcp && node scripts/smoke-input-fidelity.mjs",
    "smoke:sid-fidelity": "npm run build:mcp && node scripts/smoke-sid-fidelity.mjs",
    "smoke:visual-runtime": "npm run build:mcp && node scripts/smoke-visual-runtime.mjs",
    "smoke:llm-debug": "npm run build:mcp && node scripts/smoke-llm-debug.mjs",
    "smoke:cart-fidelity": "npm run build:mcp && node scripts/smoke-cart-fidelity.mjs",
    "smoke:sid-polish": "npm run build:mcp && node scripts/smoke-sid-polish.mjs",
    "smoke:perf-ops": "npm run build:mcp && node scripts/smoke-perf-ops.mjs",
    "regress": "npm run build:mcp && node scripts/regress.mjs",
    "start": "tsx src/cli.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^8.0.8"
  }
}
